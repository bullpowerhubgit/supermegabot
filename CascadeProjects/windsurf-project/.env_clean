# MCP SERVER CONFIGURATION
# =============================================================================

SUPABASE_MCP_URL=https://mcp.supabase.com/mcp?project_ref=your-project-ref
SUPABASE_MCP_PROJECT_REF=your-project-ref
MCP_ADD_COMMAND=claude mcp add --scope project --transport http supabase "https://mcp.supabase.com/mcp?project_ref=your-project-ref"
MCP_AUTH_COMMAND=claude /mcp

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

NODE_ENV=production
ENVIRONMENT=production
DEBUG=false
TZ=Europe/Vienna
LOG_LEVEL=info
DB_POOL_SIZE=10
DB_TIMEOUT=30000
CACHE_TTL=3600
CACHE_SIZE=1000
REDIS_URL=redis://localhost:6379
API_BASE_URL=https://api.anthropic.com/v1
