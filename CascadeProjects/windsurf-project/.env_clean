SHOPIFY_CLIENT_ID=YOUR_SHOPIFY_CLIENT_ID_HERE
SHOPIFY_CLIENT_SECRET=shpss_YOUR_SHOPIFY_CLIENT_SECRET_HERE

# =============================================================================
# DATABASE & STORAGE
# =============================================================================

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR_SUPABASE_ANON_KEY_HERE
