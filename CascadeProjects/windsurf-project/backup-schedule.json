{
  "enabled": true,
  "schedules": [
    {
      "id": "daily-backup",
      "name": "Daily Full Backup",
      "frequency": "daily",
      "time": "02:00",
      "days": [],
      "enabled": true,
      "type": "full",
      "providers": [
        "gdrive",
        "aws"
      ],
      "retention": {
        "daily": 7,
        "weekly": 4,
        "monthly": 12
      }
    },
    {
      "id": "weekly-backup",
      "name": "Weekly Full Backup",
      "frequency": "weekly",
      "time": "03:00",
      "days": [
        "sunday"
      ],
      "enabled": true,
      "type": "full",
      "providers": [
        "gdrive",
        "aws",
        "azure"
      ],
      "retention": {
        "daily": 7,
        "weekly": 4,
        "monthly": 12
      }
    },
    {
      "id": "monthly-backup",
      "name": "Monthly Archive Backup",
      "frequency": "monthly",
      "time": "04:00",
      "days": [
        "1"
      ],
      "enabled": true,
      "type": "archive",
      "providers": [
        "gdrive",
        "aws",
        "azure"
      ],
      "retention": {
        "monthly": 24
      }
    },
    {
      "id": "config-backup",
      "name": "Configuration Backup",
      "frequency": "daily",
      "time": "01:00",
      "days": [],
      "enabled": true,
      "type": "config",
      "providers": [
        "gdrive"
      ],
      "retention": {
        "daily": 30
      }
    }
  ],
  "notifications": {
