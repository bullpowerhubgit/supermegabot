# ══════════════════════════════════════════════════════════════════════
# SuperMegaBot API Configuration Template (Secure Version)
# Kopieren Sie diese Datei und fügen Sie Ihre API-Keys ein
# ══════════════════════════════════════════════════════════════════════

# ── AI APIs (External) ───────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-YOUR_OPENAI_KEY_HERE
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_ANTHROPIC_KEY_HERE
PERPLEXITY_API_KEY=pplx-YOUR_PERPLEXITY_KEY_HERE

# ── Shopify Configuration ───────────────────────────────────────────────────────
SHOPIFY_STORE_URL=https://admin.shopify.com/store/YOUR_STORE_NAME/
SHOPIFY_SHOP_DOMAIN=your-store.myshopify.com
SHOPIFY_API_VERSION=2026-04
SHOPIFY_ACCESS_TOKEN=shpat_YOUR_SHOPIFY_ACCESS_TOKEN_HERE
SHOPIFY_CLIENT_ID=YOUR_SHOPIFY_CLIENT_ID_HERE
SHOPIFY_CLIENT_SECRET=shpss_YOUR_SHOPIFY_CLIENT_SECRET_HERE
SHOPIFY_WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET_HERE

# ── Social Media Platforms ─────────────────────────────────────────────────────
TIKTOK_ACCESS_TOKEN=YOUR_TIKTOK_ACCESS_TOKEN_HERE
PINTEREST_ACCESS_TOKEN=YOUR_PINTEREST_ACCESS_TOKEN_HERE
META_ACCESS_TOKEN=YOUR_META_ACCESS_TOKEN_HERE
META_PAGE_ID=YOUR_META_PAGE_ID_HERE
REDDIT_CLIENT_ID=YOUR_REDDIT_CLIENT_ID_HERE
REDDIT_CLIENT_SECRET=YOUR_REDDIT_CLIENT_SECRET_HERE
YOUTUBE_API_KEY=YOUR_YOUTUBE_API_KEY_HERE
YOUTUBE_CHANNEL_ID=YOUR_YOUTUBE_CHANNEL_ID_HERE
TWITTER_BEARER_TOKEN=YOUR_TWITTER_BEARER_TOKEN_HERE
DISCORD_BOT_TOKEN=YOUR_DISCORD_BOT_TOKEN_HERE
DISCORD_WEBHOOK_URL=YOUR_DISCORD_WEBHOOK_URL_HERE

# ── Print-on-Demand Services ───────────────────────────────────────────────────
PRINTIFY_TOKEN=YOUR_PRINTIFY_TOKEN_HERE
PRINTIFY_API_TOKEN=YOUR_PRINTIFY_API_TOKEN_HERE
PRINTIFY_SHOP_ID=YOUR_PRINTIFY_SHOP_ID_HERE

# ── Marketplace & Commerce Platforms ───────────────────────────────────────────
ETSY_API_KEY=YOUR_ETSY_API_KEY_HERE
ETSY_SHARED_SECRET=YOUR_ETSY_SHARED_SECRET_HERE
GUMROAD_CLIENT_ID=YOUR_GUMROAD_CLIENT_ID_HERE
GUMROAD_CLIENT_SECRET=YOUR_GUMROAD_CLIENT_SECRET_HERE
DIGISTORE24_API_KEY=YOUR_DIGISTORE24_API_KEY_HERE

# ── Email Marketing Automation ─────────────────────────────────────────────────
KLAVIYO_API_KEY=pk_YOUR_KLAVIYO_API_KEY_HERE
MAILCHIMP_API_KEY=YOUR_MAILCHIMP_API_KEY_HERE-usXX
MAILCHIMP_SERVER_PREFIX=usXX

# ── Database & Storage ───────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/your-database
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR_SUPABASE_ANON_KEY_HERE
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR_SUPABASE_SERVICE_KEY_HERE

# ── Telegram Bot Configuration ─────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID_HERE

# ── GitHub Integration ───────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_YOUR_GITHUB_TOKEN_HERE
GITHUB_CLIENT_ID=YOUR_GITHUB_CLIENT_ID_HERE
GITHUB_CLIENT_SECRET=YOUR_GITHUB_CLIENT_SECRET_HERE

# ── Google Services ───────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET_HERE

# ── Meta / Facebook Services ─────────────────────────────────────────────────
FACEBOOK_APP_ID=YOUR_FACEBOOK_APP_ID_HERE
FACEBOOK_APP_SECRET=YOUR_FACEBOOK_APP_SECRET_HERE
FACEBOOK_PIXEL_ID=YOUR_FACEBOOK_PIXEL_ID_HERE
FACEBOOK_BUSINESS_ID=YOUR_FACEBOOK_BUSINESS_ID_HERE
FACEBOOK_PAGE_ID=YOUR_FACEBOOK_PAGE_ID_HERE

# ══════════════════════════════════════════════════════════════════════
# ANLEITUNG:
# 1. Kopieren Sie diese Datei
# 2. Ersetzen Sie alle "YOUR_..._HERE" mit Ihren echten API-Keys
# 3. Benennen Sie die Datei um in ".env"
# 4. Platzieren Sie sie im Hauptverzeichnis Ihres Projekts
# 5. Fügen Sie ".env" zu Ihrer .gitignore Datei hinzu!
# ══════════════════════════════════════════════════════════════════════
