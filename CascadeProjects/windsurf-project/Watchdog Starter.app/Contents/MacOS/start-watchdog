#!/bin/bash

APP_DIR="$(cd "$(dirname "$0")/.." && pwd)"
PROJECT_DIR="/Users/rudolfsarkany/supermegabot-windsurf-agents/CascadeProjects/windsurf-project"
PIDFILE="/tmp/supermegabot-watchdog.pid"

show_notification() {
    osascript -e "display notification \"$2\" with title \"$1\" sound name \"Glass\""
}

# Check if already running
if [ -f "$PIDFILE" ]; then
    PID=$(cat "$PIDFILE")
    if ps -p "$PID" > /dev/null 2>&1; then
        show_notification "Watchdog" "Läuft bereits (PID: $PID)"
        exit 0
    fi
fi

cd "$PROJECT_DIR"

# Start watchdog in background
nohup /opt/homebrew/bin/node "$PROJECT_DIR/watchdog.js" > /dev/null 2>&1 &
PID=$!
echo $PID > "$PIDFILE"

show_notification "Watchdog" "Gestartet! PID: $PID"

# Optional: open log after 2 seconds
(sleep 2 && open -a Console /tmp/supermegabot-watchdog.log) &
