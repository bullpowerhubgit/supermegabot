{
  "providers": {
    "gdrive": {
      "enabled": true,
      "credentials": "path/to/gdrive-credentials.json",
      "folderId": "your-backup-folder-id"
    },
    "aws": {
      "enabled": true,
      "accessKeyId": "",
      "secretAccessKey": "",
      "region": "us-east-1",
      "bucket": "supermegabot-backups"
    },
    "azure": {
      "enabled": true,
      "accountName": "",
      "accountKey": "",
      "container": "supermegabot-backups"
    },
    "dropbox": {
      "enabled": false,
      "accessToken": "",
      "folder": "/SuperMegaBot/Backups"
    }
  },
  "schedule": {
    "enabled": true,
    "frequency": "daily",
    "time": "02:00",
    "retention": {
      "daily": 7,
      "weekly": 4,
      "monthly": 12
    }
  },
  "compression": {
    "enabled": true,
    "level": 6
  },
  "encryption": {
    "enabled": true,
    "algorithm": "aes-256-gcm"
  },
  "notifications": {
    "enabled": true,
    "email": "admin@supermegabot.com",
    "telegram": true
  }
}