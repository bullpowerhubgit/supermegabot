#!/bin/bash

PIDFILE="/tmp/supermegabot-watchdog.pid"

show_notification() {
    osascript -e "display notification \"$2\" with title \"$1\" sound name \"Glass\""
}

# Check if running
if [ ! -f "$PIDFILE" ]; then
    show_notification "Watchdog" "Läuft nicht"
    exit 0
fi

PID=$(cat "$PIDFILE")

if ps -p "$PID" > /dev/null 2>&1; then
    kill "$PID"
    rm "$PIDFILE"
    show_notification "Watchdog" "Gestoppt! (PID: $PID)"
else
    rm "$PIDFILE"
    show_notification "Watchdog" "PID-Datei gelöscht (Prozess war bereits tot)"
fi
