#!/bin/bash

PROJECT_DIR="/Users/rudolfsarkany/supermegabot-windsurf-agents/CascadeProjects/windsurf-project"
ECOSYSTEM="/Users/rudolfsarkany/supermegabot-windsurf-agents/ecosystem.config.js"
PIDFILE_WD="/tmp/supermegabot-watchdog.pid"
PIDFILE_DS="/tmp/supermegabot-deepscan.pid"

notify() {
    osascript -e "display notification \"$2\" with title \"$1\" sound name \"Glass\""
}

dialog() {
    osascript <<EOF
try
    set btn to button returned of (display dialog "$1" buttons {"Starten", "Stoppen", "Status prüfen"} default button "Status prüfen" with icon note with title "SuperMegaBot Control")
    return btn
on error
    return "cancel"
end try
EOF
}

status_text() {
    local wd=""
    local ds=""
    local pm2=""
    
    if [ -f "$PIDFILE_WD" ] && ps -p "$(cat $PIDFILE_WD)" > /dev/null 2>&1; then
        wd="Watchdog: LAUFT (PID $(cat $PIDFILE_WD))"
    else
        wd="Watchdog: STOPPED"
    fi
    
    if [ -f "$PIDFILE_DS" ] && ps -p "$(cat $PIDFILE_DS)" > /dev/null 2>&1; then
        ds="DeepScan: LAUFT (PID $(cat $PIDFILE_DS))"
    else
        ds="DeepScan: STOPPED"
    fi
    
    if which pm2 > /dev/null 2>&1; then
        local pm2count=$(pm2 list 2>/dev/null | grep -c "online" || echo "0")
        pm2="PM2: $pm2count Apps online"
    else
        pm2="PM2: NICHT INSTALLIERT"
    fi
    
    echo "$wd
$ds
$pm2"
}

start_all() {
    cd "$PROJECT_DIR"
    
    # Start Watchdog
    if [ ! -f "$PIDFILE_WD" ] || ! ps -p "$(cat $PIDFILE_WD)" > /dev/null 2>&1; then
        nohup /opt/homebrew/bin/node "$PROJECT_DIR/watchdog.js" > /dev/null 2>&1 &
        PID_WD=$!
        echo $PID_WD > "$PIDFILE_WD"
        notify "SuperMegaBot" "Watchdog gestartet"
    fi
    
    # Start DeepScan
    if [ ! -f "$PIDFILE_DS" ] || ! ps -p "$(cat $PIDFILE_DS)" > /dev/null 2>&1; then
        nohup /opt/homebrew/bin/node "$PROJECT_DIR/deep-scan-scheduler.js" > /dev/null 2>&1 &
        PID_DS=$!
        echo $PID_DS > "$PIDFILE_DS"
        notify "SuperMegaBot" "DeepScan gestartet"
    fi
    
    # Start PM2 Ecosystem
    if which pm2 > /dev/null 2>&1; then
        pm2 start "$ECOSYSTEM" > /tmp/pm2-start.log 2>&1
        notify "SuperMegaBot" "PM2 Ecosystem gestartet"
    fi
    
    sleep 1
    notify "SuperMegaBot" "Alle Services gestartet!"
}

stop_all() {
    # Stop Watchdog
    if [ -f "$PIDFILE_WD" ]; then
        PID=$(cat "$PIDFILE_WD")
        kill "$PID" 2>/dev/null
        rm -f "$PIDFILE_WD"
    fi
    
    # Stop DeepScan
    if [ -f "$PIDFILE_DS" ]; then
        PID=$(cat "$PIDFILE_DS")
        kill "$PID" 2>/dev/null
        rm -f "$PIDFILE_DS"
    fi
    
    # Stop PM2
    if which pm2 > /dev/null 2>&1; then
        pm2 stop all > /tmp/pm2-stop.log 2>&1
    fi
    
    notify "SuperMegaBot" "Alle Services gestoppt!"
}

# Main
CHOICE=$(dialog "SuperMegaBot Control\n$(status_text)")

case "$CHOICE" in
    "Starten")
        start_all
        ;;
    "Stoppen")
        stop_all
        ;;
    "Status prüfen")
        osascript -e "display dialog \"$(status_text)\" buttons {\"OK\"} default button \"OK\" with icon note with title \"SuperMegaBot Status\""
        ;;
    *)
        exit 0
        ;;
esac
