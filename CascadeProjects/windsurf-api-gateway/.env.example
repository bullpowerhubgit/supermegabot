# 🌐 WINDSURF API GATEWAY - Environment Variables
# Kopiere nach .env und fülle deine Werte ein

# Gateway Konfiguration
PORT=8080
NODE_ENV=production
API_VERSION=v1

# 🛡️ Security
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=24h
API_KEY_SECRET=your_api_key_secret_here

# 🔗 Service URLs (interne Kommunikation)
RUDIBOT_URL=http://localhost:3200
MEGA_DASHBOARD_URL=http://localhost:3000
SHOPIFY_API_URL=http://localhost:3001
TELEGRAM_BOT_URL=http://localhost:3002
ACQUISITION_ENGINE_URL=http://localhost:3003

# 📊 Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# 📝 Logging
LOG_LEVEL=info
LOG_FORMAT=json

# 🗄️ Datenbank
DATABASE_URL=your_database_url_here
REDIS_URL=redis://localhost:6379

# 🔔 Monitoring
SENTRY_DSN=your_sentry_dsn_here
HEALTH_CHECK_INTERVAL=30000

# 💰 Stripe/Paddle für Monetarisierung
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
PADDLE_API_KEY=your_paddle_api_key
PADDLE_VENDOR_ID=your_paddle_vendor_id
