# RUDIBOT Revenue First Mode - Echte Produktions-ENV
# Nur echte APIs und Live-Daten - KEINE Platzhalter!

# ============================================================
# SHOPIFY - ECHTE STORE DATEN
# ============================================================
SHOPIFY_STORE_URL=https://your-store.myshopify.com
SHOPIFY_ADMIN_TOKEN=shpat_your_real_admin_token_here
SHOPIFY_API_VERSION=2025-01
SHOPIFY_LOCATION_ID=your_location_id

# ============================================================
# PAYPAL - ECHTE BUSINESS ACCOUNT
# ============================================================
PAYPAL_CLIENT_ID=your_real_paypal_client_id
PAYPAL_CLIENT_SECRET=your_real_paypal_client_secret
PAYPAL_SANDBOX=false

# ============================================================
# PRINTIFY - ECHTER ACCOUNT
# ============================================================
PRINTIFY_API_KEY=your_real_printify_api_key
PRINTIFY_SHOP_ID=your_real_shop_id

# ============================================================
# BANKING - ECHTE KONTODATEN
# ============================================================
BANK_IMPORT_PATH=./imports/bank
BANK_API_TOKEN=your_real_bank_api_token

# ============================================================
# NOTIFICATIONS - ECHTE KANÄLE
# ============================================================
TELEGRAM_BOT_TOKEN=your_real_telegram_bot_token
TELEGRAM_CHAT_ID=your_real_chat_id
RESEND_API_KEY=re_your_real_resend_api_key
EMAIL_FROM=noreply@yourdomain.com

# ============================================================
# SECURITY - ECHTE SCHLÜSSEL
# ============================================================
OPENAI_API_KEY=sk-PLACEHOLDER_OPENAI_KEY
ANTHROPIC_API_KEY=your_real_anthropic_api_key

# ============================================================
# INFRASTRUCTURE - ECHTE SYSTEME
# ============================================================
NODE_ENV=production
PORT=3200
DOMAIN=yourdomain.com
SSL_CERT_PATH=/etc/ssl/certs/yourdomain.com.crt
SSL_KEY_PATH=/etc/ssl/private/yourdomain.com.key

# ============================================================
# MONITORING - ECHTE TRACKING
# ============================================================
SENTRY_DSN=https://your_real_sentry_dsn
LOG_LEVEL=info
METRICS_ENABLED=true

# ============================================================
# BACKUP - ECHTE SPEICHER
# ============================================================
BACKUP_S3_BUCKET=your-backup-bucket
BACKUP_S3_REGION=eu-central-1
BACKUP_S3_ACCESS_KEY=your_s3_access_key
BACKUP_S3_SECRET_KEY=your_s3_secret_key

# ============================================================
# CRITICAL - KEINE DEMO DATEN
# ============================================================
# Alle oben genannten Keys müssen echte, funktionierende Werte enthalten
# Keine Platzhalter, keine Test-Daten, keine Mockups
# Revenue First Mode funktioniert nur mit echten Geschäftsdaten
