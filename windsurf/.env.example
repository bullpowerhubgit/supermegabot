# ============================================
# RUDIBOT KING OF TOOLS - Environment Template
# ============================================
# NEVER commit real values! Use .env.local or Vercel/Railway env vars.

# === Core Server ===
NODE_ENV=development
PORT=3001
VERCEL=false

# === Database (Supabase) ===
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# === Auth (Supabase Auth / JWT) ===
JWT_SECRET=your-jwt-secret-min-32-characters-long
AUTH_WEBHOOK_SECRET=whsec_your-webhook-secret

# === AI / LLM ===
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
PERPLEXITY_API_KEY=pplx-your-perplexity-key

# === Google Cloud Platform ===
GCP_PROJECT_ID=your-gcp-project-id
GCP_CONFIG={"type":"service_account","project_id":"your-project"}
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# === Shopify ===
SHOPIFY_SHOP_DOMAIN=your-shop.myshopify.com
SHOPIFY_ACCESS_TOKEN=your-shopify-access-token
SHOPIFY_API_KEY=your-shopify-api-key
SHOPIFY_API_SECRET=your-shopify-api-secret

# === Email ===
SENDGRID_API_KEY=SG.your-sendgrid-key
RESEND_API_KEY=re_your-resend-key
MAILCHIMP_API_KEY=your-mailchimp-key-us1
KLAVIYO_API_KEY=pk_your-klaviyo-key

# === SMS ===
TWILIO_ACCOUNT_SID=AC_your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+1234567890

# === Payment (Stripe) ===
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_STARTER_PRICE_ID=price_your-starter-plan
STRIPE_PRO_PRICE_ID=price_your-pro-plan
STRIPE_ENTERPRISE_PRICE_ID=price_your-enterprise-plan

# === PayPal ===
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret

# === Communication ===
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
DISCORD_BOT_TOKEN=your-discord-bot-token
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# === Social Media ===
TWITTER_API_KEY=your-twitter-api-key
TWITTER_API_SECRET=your-twitter-api-secret
TWITTER_BEARER_TOKEN=your-twitter-bearer-token
FACEBOOK_ACCESS_TOKEN=your-facebook-access-token

# === CRM / Support ===
HUBSPOT_API_KEY=your-hubspot-api-key
SALESFORCE_USERNAME=your-salesforce-username
SALESFORCE_PASSWORD=your-salesforce-password
SALESFORCE_SECURITY_TOKEN=your-salesforce-token
PIPEDRIVE_API_KEY=your-pipedrive-api-key
ZENDESK_SUBDOMAIN=your-subdomain
ZENDESK_EMAIL=your-email@example.com
ZENDESK_API_TOKEN=your-zendesk-token
INTERCOM_ACCESS_TOKEN=your-intercom-token

# === Project Management ===
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_USERNAME=your-email@example.com
JIRA_API_TOKEN=your-jira-api-token
TRELLO_API_KEY=your-trello-api-key
TRELLO_TOKEN=your-trello-token
ASANA_ACCESS_TOKEN=your-asana-token

# === Storage / Cloud ===
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AZURE_CONNECTION_STRING=your-azure-connection-string

# === Heroku / Cloudflare ===
HEROKU_API_KEY=your-heroku-api-key
CLOUDFLARE_API_KEY=your-cloudflare-api-key
CLOUDFLARE_EMAIL=your-email@example.com
CLOUDFLARE_ZONE_ID=your-cloudflare-zone-id

# === GitHub ===
GITHUB_TOKEN=ghp_your-github-token
GITHUB_OWNER=your-github-username

# === Notion / Airtable ===
NOTION_API_KEY=secret_your-notion-key
NOTION_DATABASE_ID=your-notion-database-id
AIRTABLE_API_KEY=pat_your-airtable-key
AIRTABLE_BASE_ID=your-airtable-base-id

# === OpenClaw / AI Assistant ===
OPENCLAW_URL=http://127.0.0.1:18789
OPENCLAW_TOKEN=your-openclaw-token
OPENCLAW_MODEL=anthropic/claude-sonnet-4-20250514

# === Webhook Security ===
WEBHOOK_SECRET=your-webhook-signing-secret-min-32-chars
HMAC_SECRET=your-hmac-secret-min-32-characters-long

# === Monitoring ===
SENTRY_DSN=your-sentry-dsn
LOG_LEVEL=info
