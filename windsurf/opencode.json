{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-sonnet-4-20250514",
  "permission": {
    "bash": "allow",
    "edit": "allow",
    "read": "allow",
    "grep": "allow",
    "glob": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "question": "allow",
    "skill": "allow",
    "todowrite": "allow",
    "lsp": "allow",
    "patch": "allow"
  },
  "provider": {
    "anthropic": {
      "models": {
        "claude-sonnet-4-20250514": {
          "options": {
            "thinking": {
              "type": "enabled",
              "budgetTokens": 16000
            }
          }
        }
      }
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": false,
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      }
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": false
    }
  },
  "agent": {
    "review": {
      "prompt": "{file:./.opencode/agents/review.md}"
    },
    "security-auditor": {
      "prompt": "{file:./.opencode/agents/security-auditor.md}"
    },
    "explore": {
      "prompt": "{file:./.opencode/agents/explore.md}"
    }
  }
}
