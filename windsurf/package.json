{
  "name": "apitool",
  "version": "1.0.0",
  "description": "Universal KI-Assistent - überall implementierbar: Terminal, Browser, API, Library",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./api": {
      "import": "./dist/api/server.js",
      "types": "./dist/api/server.d.ts"
    },
    "./cli": {
      "import": "./dist/cli/index.js",
      "types": "./dist/cli/index.d.ts"
    }
  },
  "bin": {
    "apitool": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc && npm run build:extension",
    "build:extension": "mkdir -p dist/extension && cp -r src/extension/* dist/extension/",
    "dev": "tsx watch src/api/server.ts",
    "start": "node dist/api/server.js",
    "dashboard": "node unified-dashboard/server.js",
    "cli": "tsx src/cli/index.ts",
    "electron": "electron .",
    "pack": "electron-packager . apitool --platform=darwin --arch=x64 --out=dist/",
    "pack:arm": "electron-packager . apitool --platform=darwin --arch=arm64 --out=dist/"
  },
  "keywords": [
    "ai",
    "assistant",
    "cli",
    "browser-extension",
    "api"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "@aws-sdk/client-lambda": "^3.0.0",
    "@aws-sdk/client-s3": "^3.0.0",
