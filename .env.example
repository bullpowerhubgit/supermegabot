# SuperMegaBot — Beispiel-Umgebungsvariablen
# Kopiere in .env und passe die Werte an.

# ── Dashboard ────────────────────────────────────────────────────────────────
DASHBOARD_PORT=8888

# ── Ollama (lokale LLM) ──────────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434

# ── Telegram Bot ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── KI Provider (optional) ──────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Shopify ──────────────────────────────────────────────────────────────────
SHOPIFY_STORE_URL=
SHOPIFY_ADMIN_API_TOKEN=
SHOPIFY_ACCESS_TOKEN=

# ── Guardian / Eternal Bot (optional) ────────────────────────────────────────
GUARDIAN_API_SECRET=
ETERNAL_BOT_DIR=

# ── Externe Service-Pfade (überschreiben die ~/HOME-basierten Defaults) ─────
TELEGRAM_BOT_DIR=
WS_TELEGRAM_DIR=
SHOPIFY_SUITE_DIR=
SHOPIFY_AI_DIR=
GITHUB_APP_DIR=
API_GATEWAY_DIR=
AUTO_HEAL_DIR=
PASSWORD_SYNC_DIR=
DIGIFABRIK_DIR=
KIVO_DIR=
CREATORHUB_DIR=

# ── Bot Hub ──────────────────────────────────────────────────────────────────
# URL der SuperMegaBot Dashboard API, an die der Telegram-Bot Befehle weiterleitet
SUPERMEGABOT_DASHBOARD_URL=http://localhost:8888
