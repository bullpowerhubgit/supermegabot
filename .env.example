# SuperMegaBot — Beispiel-Umgebungsvariablen
# Kopiere diese Datei nach .env und trage deine Keys ein.
# Pflichtfelder sind mit [PFLICHT] markiert.

# ── Dashboard ────────────────────────────────────────────────────────────────
DASHBOARD_PORT=8888
DASHBOARD_URL=http://localhost:8888

# ── Ollama (lokale LLM) ──────────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_FAST_MODEL=llama3.2
OLLAMA_SMART_MODEL=llama3.2:70b
OLLAMA_DEFAULT_MODEL=llama3.2
OLLAMA_CODE_MODEL=codellama
OLLAMA_ANALYSIS_MODEL=llama3.2

# ── Telegram Bot [PFLICHT für Bot-Funktionen] ────────────────────────────────
# BotFather → /newbot → Token
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── KI Provider ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
PERPLEXITY_API_KEY=

# ── Shopify [PFLICHT für Shopify-Features] ────────────────────────────────────
# yourstore.myshopify.com (ohne https://)
SHOPIFY_SHOP_DOMAIN=
SHOPIFY_SHOP=
SHOPIFY_STORE_URL=
SHOPIFY_ADMIN_API_TOKEN=
SHOPIFY_ACCESS_TOKEN=
SHOPIFY_WEBHOOK_SECRET=
SHOPIFY_API_VERSION=2024-10
# Shopify CLI OAuth (optional, für atkn_ Token-Flow)
SHOPIFY_CLI_CLIENT_ID=
SHOPIFY_CLI_REFRESH_TOKEN=
SHOPIFY_CREDENTIALS_CLIENT_ID=
SHOPIFY_CREDENTIALS_CLIENT_SECRET=
# Für Suite-Deployment auf Railway:
SHOPIFY_SUITE_ACCESS_TOKEN=
SHOPIFY_SUITE_URL=https://shopify-suite-v2-production.up.railway.app

# ── Stripe ────────────────────────────────────────────────────────────────────
# Stripe Dashboard → Developers → API Keys → Secret key
STRIPE_SECRET_KEY=
# Stripe Dashboard → Developers → Webhooks → Signing secret
STRIPE_WEBHOOK_SECRET=
# Alias (einige Module nutzen STRIPE_API_KEY)
STRIPE_API_KEY=

# ── Google OAuth2 / Drive / Ads ───────────────────────────────────────────────
# GCP Console → APIs & Services → Credentials → OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Callback-URL (muss in GCP Console als Authorized redirect URI eingetragen sein)
GOOGLE_REDIRECT_URI=http://localhost:8888/api/google/callback
# Wird automatisch nach OAuth-Login befüllt:
GOOGLE_ACCESS_TOKEN=
GOOGLE_REFRESH_TOKEN=
# Service Account (Base64-kodierter JSON-Inhalt)
GCP_PROJECT_ID=
GCP_REGION=us-central1
GCP_SERVICE_ACCOUNT_JSON_B64=
GOOGLE_APPLICATION_CREDENTIALS=
# Google Ads (optional)
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_DEVELOPER_TOKEN=
# Google Merchant Center (optional)
GMC_MERCHANT_ID=
# YouTube (optional)
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=

# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# ── GitHub ────────────────────────────────────────────────────────────────────
# GitHub → Settings → Developer settings → Personal access tokens
GITHUB_TOKEN=
GITHUB_USER=

# ── Digistore24 ──────────────────────────────────────────────────────────────
DIGISTORE24_API_KEY=

# ── Klaviyo ──────────────────────────────────────────────────────────────────
KLAVIYO_API_KEY=

# ── Mailchimp ────────────────────────────────────────────────────────────────
MAILCHIMP_API_KEY=
MAILCHIMP_SERVER_PREFIX=us1

# ── Printify ─────────────────────────────────────────────────────────────────
PRINTIFY_API_KEY=
PRINTIFY_API_TOKEN=
PRINTIFY_SHOP_ID=

# ── Etsy ─────────────────────────────────────────────────────────────────────
ETSY_API_KEY=
ETSY_SHARED_SECRET=
ETSY_ACCESS_TOKEN=
ETSY_SHOP_ID=

# ── Gumroad ──────────────────────────────────────────────────────────────────
GUMROAD_ACCESS_TOKEN=

# ── Social Media ─────────────────────────────────────────────────────────────
META_ACCESS_TOKEN=
META_PAGE_ID=
FACEBOOK_PIXEL_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=
INSTAGRAM_ACCESS_TOKEN=
TIKTOK_ACCESS_TOKEN=
PINTEREST_ACCESS_TOKEN=

# ── SEO / SEMrush ─────────────────────────────────────────────────────────────
SEMRUSH_API_KEY=

# ── Tailscale (optional, für Netzwerk-Monitoring) ─────────────────────────────
TAILSCALE_API_KEY=
TAILSCALE_TAILNET=

# ── Freelancing (optional) ────────────────────────────────────────────────────
FIVERR_CLIENT_ID=
FIVERR_CLIENT_SECRET=
INDEED_PUBLISHER_ID=

# ── Storage Monitoring (optionale Schwellwerte) ───────────────────────────────
STORAGE_WARN_PCT=80
STORAGE_CRITICAL_PCT=90
STORAGE_CHECK_INTERVAL=300
RAM_WARN_PCT=85
BACKUP_EXTRA_DIRS=

# ── Daten-Pfad ────────────────────────────────────────────────────────────────
DATA_DIR=

# ── Externe Service-Pfade (überschreiben ~/HOME-basierte Defaults) ───────────
SUPERMEGABOT_DIR=
TELEGRAM_BOT_DIR=
WS_TELEGRAM_DIR=
SHOPIFY_SUITE_DIR=
SHOPIFY_AI_DIR=
GITHUB_APP_DIR=
API_GATEWAY_DIR=
AUTO_HEAL_DIR=
PASSWORD_SYNC_DIR=
DIGIFABRIK_DIR=
KIVO_DIR=
CREATORHUB_DIR=
ETERNAL_BOT_DIR=

# ── Bot Hub ───────────────────────────────────────────────────────────────────
SUPERMEGABOT_DASHBOARD_URL=http://localhost:8888
GUARDIAN_API_SECRET=
