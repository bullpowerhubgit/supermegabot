# Gumroad
# Get token: https://app.gumroad.com/api — Create Application → Access Token
GUMROAD_ACCESS_TOKEN=

# Fiverr
FIVERR_API_KEY=your_fiverr_api_key_here
FIVERR_USERNAME=your_fiverr_username

# Upwork
UPWORK_CLIENT_ID=your_upwork_client_id
UPWORK_CLIENT_SECRET=your_upwork_client_secret
UPWORK_ACCESS_TOKEN=your_upwork_access_token

# Printify (Print-on-Demand)
# Get your Shop ID via: GET https://api.printify.com/v1/shops.json
# Or it is auto-detected on first run and cached in data/printify_shop.json
PRINTIFY_API_KEY=your_printify_api_key_here
PRINTIFY_SHOP_ID=        # Auto-detected if blank; set manually to skip API call

# Printful (Print-on-Demand)
PRINTFUL_API_KEY=your_printful_api_key_here
PRINTFUL_STORE_ID=       # Auto-detected from /stores endpoint on first run
PRINTFUL_CLIENT_ID=      # Only needed for OAuth flow
PRINTFUL_CLIENT_SECRET=  # Only needed for OAuth flow

# TikTok Shop
TIKTOK_APP_KEY=
TIKTOK_APP_SECRET=
TIKTOK_ACCESS_TOKEN=
TIKTOK_SHOP_ID=
TIKTOK_REDIRECT_URI=https://dudirudibot-mega-production.up.railway.app/api/tiktok/callback

# eBay Browse API + EPN Affiliate
EBAY_APP_ID=
EBAY_CERT_ID=
EBAY_OAUTH_TOKEN=
EBAY_CAMPAIGN_ID=
EBAY_AFFILIATE_ID=

# Amazon Associates + PAAPI
AMAZON_TRACKING_ID=bullpowerhub-21
AMAZON_PAAPI_KEY=
AMAZON_PAAPI_SECRET=

# Pipedrive CRM
PIPEDRIVE_API_TOKEN=your_pipedrive_api_token
PIPEDRIVE_COMPANY_DOMAIN=aiitec

# SemRush SEO API
SEMRUSH_API_KEY=your_semrush_api_key

# PayPal NVP API
PAYPAL_API_USERNAME=your_paypal_api_username
PAYPAL_API_PASSWORD=your_paypal_api_password
PAYPAL_API_SIGNATURE=your_paypal_api_signature
PAYPAL_ENVIRONMENT=production
