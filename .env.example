# ════════════════════════════════════════════════════════════════════════
# SuperMegaBot — .env.example
# Kopiere diese Datei zu .env und fülle alle Werte aus.
# NIEMALS echte Werte in diese Datei oder ins Git eintragen!
# ════════════════════════════════════════════════════════════════════════

# ── GUARDIAN API ─────────────────────────────────────────────────────────
# Das Secret für die Guardian REST API (min. 32 zufällige Zeichen)
# Generieren: python3 -c "import secrets; print(secrets.token_hex(32))"
GUARDIAN_API_SECRET=
GUARDIAN_API_HOST=0.0.0.0
GUARDIAN_API_PORT=3201
GUARDIAN_API_AUTH=true
GUARDIAN_WEBHOOK_SECRET=
# Optionaler Override wenn Guardian nicht auf localhost läuft
GUARDIAN_URL=http://localhost:3201

# ── SUPERMEGABOT DASHBOARD ───────────────────────────────────────────────
PORT=8888
DASHBOARD_PORT=8888
DASHBOARD_URL=http://localhost:8888
SUPERMEGABOT_URL=http://localhost:8888

# ── SHOPIFY ──────────────────────────────────────────────────────────────
# Deine Shopify-Store-Domain (z.B. meinshop.myshopify.com)
SHOPIFY_SHOP_DOMAIN=
# Kurzname ohne .myshopify.com (wird intern gebraucht)
SHOPIFY_SHOP=
# Admin API URL
SHOPIFY_STORE_URL=
# Admin API Access Token (shpat_...) — von Shopify Admin > Apps > API-Zugangsdaten
SHOPIFY_ACCESS_TOKEN=
# Falls du die Shopify Suite nutzt (Railway-Deployment)
SHOPIFY_SUITE_ACCESS_TOKEN=
SHOPIFY_SUITE_URL=https://shopify-suite-v2-production.up.railway.app
# OAuth / Client Credentials (für Auto-Refresh)
SHOPIFY_CLI_CLIENT_ID=
SHOPIFY_CLI_REFRESH_TOKEN=
SHOPIFY_CREDENTIALS_CLIENT_ID=
SHOPIFY_CREDENTIALS_CLIENT_SECRET=
# API Version (aktuell: 2024-10)
SHOPIFY_API_VERSION=2024-10

# ── TELEGRAM ─────────────────────────────────────────────────────────────
# Bot-Token von @BotFather
TELEGRAM_BOT_TOKEN=
# Chat-ID deines Telegram-Accounts oder -Kanals (z.B. 123456789)
TELEGRAM_CHAT_ID=
# Nur Nachrichten von dieser User-ID akzeptieren
AUTHORIZED_USER_ID=

# ── STRIPE ───────────────────────────────────────────────────────────────
# Stripe Secret Key (sk_live_... oder sk_test_... für Tests)
STRIPE_SECRET_KEY=
STRIPE_API_KEY=

# ── SUPABASE ─────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=

# ── GITHUB ───────────────────────────────────────────────────────────────
GITHUB_TOKEN=
GITHUB_USER=
GITHUB_WEBHOOK_SECRET=

# ── AI / LLM ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
PERPLEXITY_API_KEY=
# Ollama (lokal, Standard: http://localhost:11434)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gemma2
OLLAMA_DEFAULT_MODEL=gemma2
OLLAMA_FAST_MODEL=gemma2:2b
OLLAMA_SMART_MODEL=gemma2:27b
OLLAMA_CODE_MODEL=codellama

# ── GOOGLE ADS / MERCHANT CENTER ─────────────────────────────────────────
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_DEVELOPER_TOKEN=
GMC_MERCHANT_ID=

# ── GOOGLE CLOUD PLATFORM (GCP) ──────────────────────────────────────────
# Projekt-ID (nicht sensitiv, sichtbar in GCP Console URLs)
GCP_PROJECT_ID=
# Pfad zur Service-Account-JSON (NIEMALS die Datei selbst ins Git!)
GOOGLE_APPLICATION_CREDENTIALS=
# Alternativ: base64-kodierter Inhalt der Service-Account-JSON
# GCP_SERVICE_ACCOUNT_JSON_B64=
# Region für Cloud-Funktionen / Storage
GCP_REGION=europe-west1
# APIs — Zugangsdaten falls API-Key-basiert (nicht Service-Account)
GOOGLE_GEMINI_API_KEY=
GOOGLE_MAPS_API_KEY=
GOOGLE_PLACES_API_KEY=
GOOGLE_TRANSLATE_API_KEY=
GOOGLE_VISION_API_KEY=
GOOGLE_SHEETS_API_KEY=
GOOGLE_DRIVE_API_KEY=
YOUTUBE_DATA_API_KEY=
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# ── TAILSCALE ────────────────────────────────────────────────────────────
TAILSCALE_API_KEY=
TAILSCALE_TAILNET=

# ── NOTIFICATIONS ────────────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=

# ── SERVICE-VERZEICHNISSE (auf deinem Mac/Server) ────────────────────────
# Nur nötig wenn bot_integrator.py Services starten soll
GUARDIAN_DIR=
TELEGRAM_BOT_DIR=
API_GATEWAY_DIR=
SHOPIFY_AI_DIR=
SHOPIFY_SUITE_DIR=
GITHUB_APP_DIR=
WS_TELEGRAM_DIR=
ETERNAL_BOT_DIR=
AUTO_HEAL_DIR=
PASSWORD_SYNC_DIR=

# ── MONITORING ───────────────────────────────────────────────────────────
RAM_WARN_PCT=85
STORAGE_WARN_PCT=80
STORAGE_CRITICAL_PCT=95
STORAGE_CHECK_INTERVAL=300
SOCIAL_AUTOPOST_INTERVAL=3600
