# SuperMegaBot — Beispiel-Umgebungsvariablen
# Kopiere in .env und passe die Werte an.

# ── Dashboard ────────────────────────────────────────────────────────────────
DASHBOARD_PORT=8888
DASHBOARD_API_KEY=your_dashboard_api_key_here

# ── Ollama (lokale LLM) ──────────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434

# ── Telegram Bot ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── KI Provider ───────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your_openai_key_here
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here
GROK_API_KEY=xai-your_grok_key_here
GROK_API_URL=https://api.x.ai/v1

# ── GitHub API ───────────────────────────────────────────────────────────────
GITHUB_TOKEN_CLASSIC=ghp_your_github_classic_token_here
GITHUB_TOKEN_FINE=github_pat_your_fine_grained_token_here
GITHUB_TOKEN_FINE_ALT=github_pat_your_alt_token_here

# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_KEY=your_service_role_key_here
SUPABASE_PROJECT_REF=your_project_ref_here

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# ── Shopify ──────────────────────────────────────────────────────────────────
SHOPIFY_STORE_URL=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=your_shopify_access_token_here
SHOPIFY_ACCESS_TOKEN_SECONDARY=your_secondary_token_here
SHOPIFY_CLIENT_ID=your_shopify_client_id_here
SHOPIFY_SHARED_SECRET=your_shopify_secret_here
SHOPIFY_REFRESH_TOKEN=your_refresh_token_here
SHOPIFY_AUTOMATION_TOKEN=your_automation_token_here
SHOPIFY_APP_URL=https://your-domain.com/webhooks/shopify
SHOPIFY_AUTH_URL=https://your-domain.com/auth/shopify

# ── Klaviyo ──────────────────────────────────────────────────────────────────
KLAVIYO_API_KEY=pk_your_klaviyo_key_here

# ── Printify ───────────────────────────────────────────────────────────────────
PRINTIFY_API_KEY=your_printify_api_key_here

# ── Vercel ────────────────────────────────────────────────────────────────────
VERCEL_TEAM_ID=your_team_id_here
VERCEL_TEAM_NAME=your_team_name_here

# ── Telegram API (WebApp) ─────────────────────────────────────────────────────
TELEGRAM_CLIENT_ID=your_telegram_client_id_here
TELEGRAM_CLIENT_SECRET=your_telegram_client_secret_here

# ── E-Commerce ───────────────────────────────────────────────────────────────────
ETSY_API_KEY=your_etsy_api_key_here
ETSY_SHARED_SECRET=your_etsy_secret_here
DIGISTORE24_API_KEY=your_digistore24_key_here

# ── Other Services ─────────────────────────────────────────────────────────────
GCP_PROJECT_ID=your_gcp_project_id_here
PERPLEXITY_API_KEY=pplx-your_perplexity_key_here
PERPLEXITY_API_URL=https://api.perplexity.ai/chat/completions
YOUTUBE_API_KEY=your_youtube_api_key_here

# ── Email Services ─────────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here

# ── Bot Hub ──────────────────────────────────────────────────────────────────
SUPERMEGABOT_DASHBOARD_URL=http://localhost:8888

# ── Guardian / Eternal Bot (optional) ────────────────────────────────────────
GUARDIAN_API_SECRET=
ETERNAL_BOT_DIR=

# ── Externe Service-Pfade (überschreiben die ~/HOME-basierten Defaults) ─────
TELEGRAM_BOT_DIR=
WS_TELEGRAM_DIR=
SHOPIFY_SUITE_DIR=
SHOPIFY_AI_DIR=
GITHUB_APP_DIR=
API_GATEWAY_DIR=
AUTO_HEAL_DIR=
PASSWORD_SYNC_DIR=
DIGIFABRIK_DIR=
KIVO_DIR=
CREATORHUB_DIR=

# ── Windsurf JS Services (optional) ──────────────────────────────────────────
SUPERMEGABOT_DIR=
SHOPIFY_API_VERSION=2024-01
NGROK_AUTHTOKEN=your_ngrok_auth_token_here

# ── WhatsApp Business API ─────────────────────────────────────────────────────
WHATSAPP_TOKEN=your_whatsapp_api_token_here
WHATSAPP_PHONE_ID=your_whatsapp_phone_number_id_here
WHATSAPP_VERIFY_TOKEN=your_webhook_verify_token_here
WHATSAPP_OWNER_NUMBER=49123456789

# ── TikTok Shop ───────────────────────────────────────────────────────────────
TIKTOK_APP_KEY=your_tiktok_app_key_here
TIKTOK_APP_SECRET=your_tiktok_app_secret_here
TIKTOK_ACCESS_TOKEN=your_tiktok_access_token_here
TIKTOK_SHOP_ID=your_tiktok_shop_id_here

# ── Revenue & Commission Settings ─────────────────────────────────────────────
DAILY_REVENUE_TARGET=1000
REFERRAL_COMMISSION_PCT=20
WINBACK_DISCOUNT_PCT=15

# ── Mailchimp ─────────────────────────────────────────────────────────────────
MAILCHIMP_API_KEY=your_mailchimp_api_key_here
MAILCHIMP_SERVER_PREFIX=us1

# ── Social Media ─────────────────────────────────────────────────────────────
META_ACCESS_TOKEN=your_meta_access_token_here
META_PAGE_ID=your_facebook_page_id_here
INSTAGRAM_ACCOUNT_ID=your_instagram_business_account_id_here
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here
TWITTER_API_KEY=your_twitter_api_key_here
TWITTER_API_SECRET=your_twitter_api_secret_here
TWITTER_ACCESS_TOKEN=your_twitter_access_token_here
TWITTER_ACCESS_SECRET=your_twitter_access_secret_here
PINTEREST_ACCESS_TOKEN=your_pinterest_access_token_here
PINTEREST_BOARD_ID=your_default_board_id_here
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
REDDIT_USERNAME=your_reddit_username_here
REDDIT_PASSWORD=your_reddit_password_here
REDDIT_DEFAULT_SUBREDDIT=ecommerce
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_CHANNEL_ID=your_discord_channel_id_here
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here

# ── Stripe Webhook ────────────────────────────────────────────────────────────
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here
