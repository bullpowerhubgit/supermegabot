# Server Configuration
PORT=3000
NODE_ENV=development
CORS_ORIGIN=*

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ALLOWED_USERS=123456789,987654321

# Shopify Configuration
SHOPIFY_SHOP_DOMAIN=your-shop.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_your_access_token_here
SHOPIFY_API_VERSION=2024-01

# Logging
LOG_LEVEL=info

# AI Configuration
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Database (if using Supabase)
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Redis (for job queue)
REDIS_URL=redis://localhost:6379

# Digistore24
DIGISTORE24_API_KEY=your_ds24_api_key_here
# IPN passphrase: set in DS24 account → Settings → IPN → Passphrase
# Used to verify sha_sign on incoming IPN webhooks (skip verification if blank)
DIGISTORE24_IPN_PASSPHRASE=
