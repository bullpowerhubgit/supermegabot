# SuperMegaBot — Beispiel-Umgebungsvariablen
# Kopiere diese Datei zu .env und passe alle Werte an.
# NIEMALS echte Secrets in dieses File eintragen!
# Letzte Aktualisierung: 2026-06-10

# ══════════════════════════════════════════════════════════════════════════════
# SYSTEM / RAILWAY / SERVER
# ══════════════════════════════════════════════════════════════════════════════
PORT=8888                                       # HTTP-Port (Railway setzt automatisch)
DASHBOARD_PORT=8888                             # Interner Dashboard-Port
DASHBOARD_URL=http://localhost:8888             # Basis-URL des Dashboards
SITE_URL=https://your-domain.com               # Öffentliche Website-URL
SUPERMEGABOT_URL=https://your-domain.com       # Öffentliche SuperMegaBot-URL
RAILWAY_PUBLIC_DOMAIN=your-app.up.railway.app  # Von Railway automatisch gesetzt
RAILWAY_STATIC_URL=https://your-app.up.railway.app  # Statische Asset-URL

# Prometheus-Metriken (optional)
PROMETHEUS_ENABLED=false                        # true = /metrics Endpunkt aktiv

# Lokale Pfade (leer lassen = Defaults gelten)
DATA_DIR=                                       # Datenpfad (default: ~/data)
OLLAMA_DIR=                                     # Ollama-Installationspfad
REDIS_DIR=                                      # Redis-Daten-Pfad
ETERNAL_BOT_DIR=                               # Pfad zum Eternal-Bot-Verzeichnis
KIVO_DIR=                                      # Pfad zum Kivo-Verzeichnis
TELEGRAM_BOT_DIR=                              # Pfad zum Telegram-Bot-Verzeichnis

# ══════════════════════════════════════════════════════════════════════════════
# TELEGRAM
# ══════════════════════════════════════════════════════════════════════════════
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ  # Haupt-Bot-Token (BotFather)
TELEGRAM_BOT_TOKEN_1=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ  # Zweiter Bot-Token
TELEGRAM_BOT_TOKEN_2=0987654321:ZYXwvuTSRqpoNMLkjiHGFedcba  # Dritter Bot-Token
TELEGRAM_CHAT_ID=-1001234567890                # Telegram Chat-/Channel-ID
AUTHORIZED_USER_ID=123456789                   # Telegram User-ID des Admins

# ══════════════════════════════════════════════════════════════════════════════
# KI-PROVIDER
# ══════════════════════════════════════════════════════════════════════════════
ANTHROPIC_API_KEY=sk-ant-api03-your_anthropic_key_here  # Claude API-Key
OPENAI_API_KEY=sk-your_openai_key_here         # OpenAI API-Key
PERPLEXITY_API_KEY=pplx-your_perplexity_key_here  # Perplexity AI API-Key

# GitHub Copilot (optional)
COPILOT_ENABLED=false                          # true = Copilot-Integration aktiv
COPILOT_MODEL=gpt-4o                           # Copilot-Modell

# Ollama (lokale LLMs)
OLLAMA_HOST=http://localhost:11434             # Ollama-Server-URL
OLLAMA_MODEL=llama3.2                          # Standard-Modell
OLLAMA_DEFAULT_MODEL=llama3.2                  # Alias für Standard-Modell
OLLAMA_FAST_MODEL=llama3.2                     # Schnelles Modell (kurze Tasks)
OLLAMA_SMART_MODEL=llama3.1:70b               # Intelligentes Modell (komplexe Tasks)
OLLAMA_ANALYSIS_MODEL=llama3.1:70b            # Analyse-Modell
OLLAMA_CODE_MODEL=qwen2.5-coder:7b            # Code-Modell

# ══════════════════════════════════════════════════════════════════════════════
# SHOPIFY
# ══════════════════════════════════════════════════════════════════════════════
SHOPIFY_SHOP_DOMAIN=your-store.myshopify.com  # Shop-Domain (ohne https://)
SHOPIFY_SHOP=your-store.myshopify.com         # Alias für Shop-Domain
SHOPIFY_STORE_URL=https://your-store.myshopify.com  # Vollständige Store-URL
SHOPIFY_STORE_NAME=Your Store Name            # Anzeigename des Shops
STORE_NAME=Your Store Name                    # Alias für Store-Namen
SHOPIFY_ACCESS_TOKEN=shpat_your_access_token_here  # Admin API Access Token
SHOPIFY_ADMIN_API_TOKEN=shpat_your_admin_token_here  # Admin API Token (Alias)
SHOPIFY_AUTOMATION_TOKEN=shpat_your_automation_token  # Token für Automatisierungen
SHOPIFY_WEBHOOK_SECRET=your_webhook_secret_here  # Webhook-Signatur-Secret
SHOPIFY_API_VERSION=2024-10                   # API-Version (z.B. 2024-10)

# Shopify OAuth / App-Credentials
SHOPIFY_CREDENTIALS_CLIENT_ID=your_shopify_client_id  # App Client-ID
SHOPIFY_CREDENTIALS_CLIENT_SECRET=your_shopify_client_secret  # App Client-Secret
SHOPIFY_CLI_CLIENT_ID=your_shopify_cli_client_id      # CLI Client-ID
SHOPIFY_CLI_REFRESH_TOKEN=your_refresh_token_here     # OAuth Refresh-Token

# Shopify Suite (zweite Installation / Staging)
SHOPIFY_SUITE_URL=https://your-suite-store.myshopify.com  # Suite Store-URL
SHOPIFY_SUITE_ACCESS_TOKEN=shpat_your_suite_token         # Suite Access Token

# Zweiter Shopify-Store (optional)
SHOPIFY_STORE2_DOMAIN=your-second-store.myshopify.com  # Domain zweiter Store
SHOPIFY_STORE2_TOKEN=shpat_your_store2_token            # Token zweiter Store

# Review-Kampagne
REVIEW_URL=https://your-store.com/reviews     # URL für Review-Anfragen
REVIEW_DELAY_DAYS=7                           # Tage nach Kauf bis Review-E-Mail

# ══════════════════════════════════════════════════════════════════════════════
# STRIPE
# ══════════════════════════════════════════════════════════════════════════════
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here   # Secret Key (test: sk_test_, live: sk_live_)
STRIPE_API_KEY=sk_test_your_stripe_secret_key_here      # Alias für Secret Key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret  # Webhook Signing Secret
STRIPE_PRICE_STARTER=price_your_starter_price_id        # Stripe Price-ID Starter-Plan (€49/mo)
STRIPE_PRICE_PRO=price_your_pro_price_id                # Stripe Price-ID Pro-Plan (€99/mo)
STRIPE_PRICE_ENTERPRISE=price_your_enterprise_price_id  # Stripe Price-ID Enterprise (€299/mo)

# ══════════════════════════════════════════════════════════════════════════════
# SUPABASE
# ══════════════════════════════════════════════════════════════════════════════
SUPABASE_URL=https://your-project-ref.supabase.co       # Projekt-URL
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your_anon_key  # Anon/Public Key
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your_service_key  # Service Role Key (Backend only!)

# Supabase für Next.js/Vercel (Public Keys)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co  # Öffentliche Projekt-URL
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your_anon_key  # Publishable Key

# ══════════════════════════════════════════════════════════════════════════════
# GITHUB
# ══════════════════════════════════════════════════════════════════════════════
GITHUB_TOKEN=ghp_your_github_personal_access_token      # Personal Access Token (classic)
GITHUB_USER=your_github_username                         # GitHub-Benutzername
GITHUB_REPO=your_github_username/supermegabot           # GitHub-Repository (user/repo)
GITHUB_WEBHOOK_SECRET=your_github_webhook_secret        # Webhook-Secret für GitHub Events

# ══════════════════════════════════════════════════════════════════════════════
# GOOGLE / GCP
# ══════════════════════════════════════════════════════════════════════════════
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com  # OAuth Client-ID
GOOGLE_CLIENT_SECRET=GOCSPX-your_google_client_secret              # OAuth Client-Secret
GOOGLE_REDIRECT_URI=https://your-domain.com/auth/google/callback   # OAuth Redirect-URI
GOOGLE_REFRESH_TOKEN=your_google_refresh_token_here                # OAuth Refresh-Token
GOOGLE_ACCESS_TOKEN=ya29.your_google_access_token_here             # OAuth Access-Token (kurzlebig)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json      # Pfad zu GCP Service Account JSON

GCP_PROJECT_ID=your-gcp-project-id                   # GCP Projekt-ID
GCP_REGION=europe-west1                               # GCP Region (z.B. europe-west1)
GCP_SERVICE_ACCOUNT_JSON_B64=base64_encoded_service_account_json  # Service Account JSON (Base64)

# Google Ads
GOOGLE_ADS_DEVELOPER_TOKEN=your_google_ads_developer_token  # Google Ads Developer Token
GOOGLE_ADS_CUSTOMER_ID=123-456-7890                          # Google Ads Customer-ID

# Google Merchant Center
GMC_MERCHANT_ID=123456789                             # Merchant Center ID
GMC_SERVICE_ACCOUNT_JSON={"type":"service_account"}  # Service Account JSON (inline)

# YouTube
YOUTUBE_API_KEY=AIzaSy_your_youtube_api_key_here      # YouTube Data API v3 Key
YOUTUBE_CHANNEL_ID=UCyour_channel_id_here             # YouTube Channel-ID

# ══════════════════════════════════════════════════════════════════════════════
# MARKETING / E-MAIL
# ══════════════════════════════════════════════════════════════════════════════
# Klaviyo
KLAVIYO_API_KEY=pk_your_klaviyo_api_key_here          # Klaviyo Private API Key

# Mailchimp
MAILCHIMP_API_KEY=your_mailchimp_api_key-usX           # Mailchimp API Key (inkl. Server-Prefix)
MAILCHIMP_SERVER_PREFIX=us1                            # Server-Prefix (z.B. us1, us6)
MAILCHIMP_LIST_ID=your_mailchimp_list_id               # Audience/List-ID

# Mandrill (Mailchimp Transactional)
MANDRILL_API_KEY=your_mandrill_api_key_here            # Mandrill API Key

# E-Mail Absender
FROM_EMAIL=noreply@your-domain.com                    # Absender-E-Mail-Adresse
FROM_NAME=SuperMegaBot                                 # Absender-Name

# Guardian API (News)
GUARDIAN_NEWS_API_KEY=your_guardian_news_api_key       # The Guardian News API Key
GUARDIAN_URL=https://content.guardianapis.com          # Guardian API URL
GUARDIAN_API_HOST=localhost                            # Guardian API Host (intern)
GUARDIAN_API_PORT=8889                                 # Guardian API Port (intern)
GUARDIAN_API_AUTH=your_guardian_auth_token             # Guardian API Auth Token
GUARDIAN_API_SECRET=your_guardian_api_secret           # Guardian API Secret
GUARDIAN_WEBHOOK_SECRET=your_guardian_webhook_secret   # Guardian Webhook Secret

# ══════════════════════════════════════════════════════════════════════════════
# SOCIAL MEDIA
# ══════════════════════════════════════════════════════════════════════════════
# Facebook / Meta / Instagram
FACEBOOK_PAGE_ACCESS_TOKEN=your_facebook_page_access_token  # Facebook Page Token
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token          # Instagram Graph API Token

# Pinterest
PINTEREST_ACCESS_TOKEN=your_pinterest_access_token     # Pinterest API Access Token

# Reddit
REDDIT_DEFAULT_SUBREDDIT=ecommerce                    # Standard-Subreddit für Posts

# TikTok Shop
TIKTOK_APP_KEY=your_tiktok_app_key                    # TikTok App Key
TIKTOK_APP_SECRET=your_tiktok_app_secret              # TikTok App Secret
TIKTOK_ACCESS_TOKEN=your_tiktok_access_token          # TikTok Access Token
TIKTOK_SHOP_ID=your_tiktok_shop_id                    # TikTok Shop ID

# Slack (optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T00/B00/your_slack_webhook  # Slack Incoming Webhook

# Discord
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_discord_webhook      # Discord Webhook URL

# ══════════════════════════════════════════════════════════════════════════════
# WHATSAPP BUSINESS API
# ══════════════════════════════════════════════════════════════════════════════
WHATSAPP_TOKEN=your_whatsapp_api_token                 # WhatsApp Business API Token
WHATSAPP_PHONE_ID=your_whatsapp_phone_number_id        # Phone Number ID (Meta Developer Console)
WHATSAPP_VERIFY_TOKEN=your_custom_webhook_verify_token # Webhook Verify Token (frei wählbar)
WHATSAPP_OWNER_NUMBER=4912345678900                    # Eigene WhatsApp-Nummer (mit Ländervorwahl)

# ══════════════════════════════════════════════════════════════════════════════
# E-COMMERCE (weitere Marktplätze)
# ══════════════════════════════════════════════════════════════════════════════
# Digistore24
DIGISTORE24_API_KEY=your_digistore24_api_key           # Digistore24 API Key

# Etsy
ETSY_API_KEY=your_etsy_api_key                         # Etsy API Key (Keystring)
ETSY_ACCESS_TOKEN=your_etsy_oauth_access_token         # Etsy OAuth Access Token
ETSY_SHOP_ID=your_etsy_shop_id                         # Etsy Shop-ID (numerisch)

# Printify (Print-on-Demand)
PRINTIFY_API_KEY=your_printify_api_key                 # Printify API Key
PRINTIFY_API_TOKEN=your_printify_api_token             # Alias für Printify Token
PRINTIFY_SHOP_ID=your_printify_shop_id                 # Printify Shop-ID

# Gumroad
GUMROAD_ACCESS_TOKEN=your_gumroad_access_token         # Gumroad API Access Token

# Fiverr (optional)
FIVERR_CLIENT_ID=your_fiverr_client_id                 # Fiverr App Client-ID
FIVERR_CLIENT_SECRET=your_fiverr_client_secret         # Fiverr App Client-Secret

# Indeed (Stellenanzeigen, optional)
INDEED_PUBLISHER_ID=your_indeed_publisher_id           # Indeed Publisher-ID

# ══════════════════════════════════════════════════════════════════════════════
# INFRASTRUKTUR
# ══════════════════════════════════════════════════════════════════════════════
# Tailscale (VPN, optional)
TAILSCALE_API_KEY=tskey-api-your_tailscale_key         # Tailscale API Key
TAILSCALE_TAILNET=your-tailnet.ts.net                  # Tailscale Tailnet-Name

# ══════════════════════════════════════════════════════════════════════════════
# BUSINESS-LOGIK / KONFIGURATION
# ══════════════════════════════════════════════════════════════════════════════
# Umsatz & Provisionen
DAILY_REVENUE_TARGET=1000                              # Tages-Umsatzziel in EUR
REFERRAL_COMMISSION_PCT=20                             # Empfehlungsprovision in %
WINBACK_DISCOUNT_PCT=15                                # Win-Back-Rabatt in %
CHURN_DAYS=90                                          # Tage bis Kunde als abgewandert gilt

# System-Monitoring
RAM_WARN_PCT=80                                        # RAM-Warngrenze in %
STORAGE_WARN_PCT=80                                    # Speicher-Warngrenze in %
STORAGE_CRITICAL_PCT=95                                # Speicher-Kritischgrenze in %
STORAGE_CHECK_INTERVAL=300                             # Prüfintervall in Sekunden

# Backup
BACKUP_EXTRA_DIRS=                                     # Zusätzliche Backup-Verzeichnisse (kommagetrennt)

# Sales / Internes Portal
SALES_PORT=8890                                        # Port für internes Sales-Portal
SALES_PASSWORD=your_sales_portal_password              # Passwort für Sales-Portal
