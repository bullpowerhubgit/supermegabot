# SuperMegaBot — Beispiel-Umgebungsvariablen
# Kopiere in .env und passe die Werte an.

# ── Dashboard ────────────────────────────────────────────────────────────────
DASHBOARD_PORT=8888

# ── Ollama (lokale LLM) ──────────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434

# ── Telegram Bot ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── KI Provider (optional) ──────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Shopify ──────────────────────────────────────────────────────────────────
SHOPIFY_STORE_URL=
SHOPIFY_ADMIN_API_TOKEN=
SHOPIFY_ACCESS_TOKEN=

# ── Guardian / Eternal Bot (optional) ────────────────────────────────────────
GUARDIAN_API_SECRET=
ETERNAL_BOT_DIR=

# ── Externe Service-Pfade (überschreiben die ~/HOME-basierten Defaults) ─────
TELEGRAM_BOT_DIR=
WS_TELEGRAM_DIR=
SHOPIFY_SUITE_DIR=
SHOPIFY_AI_DIR=
GITHUB_APP_DIR=
API_GATEWAY_DIR=
AUTO_HEAL_DIR=
PASSWORD_SYNC_DIR=
DIGIFABRIK_DIR=
KIVO_DIR=
CREATORHUB_DIR=

# ── Bot Hub ──────────────────────────────────────────────────────────────────
# URL der SuperMegaBot Dashboard API, an die der Telegram-Bot Befehle weiterleitet
SUPERMEGABOT_DASHBOARD_URL=http://localhost:8888

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
# Webhook Secret aus Stripe Dashboard → Developers → Webhooks → "whsec_..."
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Google OAuth2 / Drive ─────────────────────────────────────────────────────
# GCP Console → APIs & Services → Credentials → OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Wird automatisch nach OAuth-Login befüllt:
GOOGLE_ACCESS_TOKEN=
GOOGLE_REFRESH_TOKEN=
# Callback-URL muss in GCP Console als "Authorized redirect URI" eingetragen sein:
# http://localhost:8888/api/google/callback
GOOGLE_REDIRECT_URI=http://localhost:8888/api/google/callback

# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...

# ── Digistore24 ──────────────────────────────────────────────────────────────
DIGISTORE24_API_KEY=

# ── Klaviyo ──────────────────────────────────────────────────────────────────
KLAVIYO_API_KEY=

# ── Mailchimp ────────────────────────────────────────────────────────────────
MAILCHIMP_API_KEY=
MAILCHIMP_SERVER_PREFIX=us1

# ── Printify ─────────────────────────────────────────────────────────────────
PRINTIFY_API_KEY=
PRINTIFY_SHOP_ID=

# ── SEMrush / SEO ─────────────────────────────────────────────────────────────
SEMRUSH_API_KEY=

# ── Social Media ─────────────────────────────────────────────────────────────
META_ACCESS_TOKEN=
YOUTUBE_API_KEY=

# ── GCP ──────────────────────────────────────────────────────────────────────
GCP_PROJECT_ID=

# ── Perplexity ───────────────────────────────────────────────────────────────
PERPLEXITY_API_KEY=
