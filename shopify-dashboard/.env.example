# ═══════════════════════════════════════════════════════════════
# RUDIBOT DASHBOARD ENV - API Keys
# Kopiere diese Datei nach .env.local und füge deine echten Keys ein
# ═══════════════════════════════════════════════════════════════

# Telegram Bot Keys
REACT_APP_TELEGRAM_BOT_TOKEN=your_telegram_bot_token
REACT_APP_TELEGRAM_CHAT_ID=your_telegram_chat_id
REACT_APP_AUTHORIZED_USER_ID=your_authorized_user_id

# AI API Keys
REACT_APP_OPENAI_API_KEY=your_openai_api_key
REACT_APP_ANTHROPIC_API_KEY=your_anthropic_api_key
REACT_APP_GOOGLE_AI_API_KEY=your_google_ai_api_key
REACT_APP_PERPLEXITY_API_KEY=your_perplexity_api_key

# Shopify Keys
REACT_APP_SHOPIFY_WEBHOOK_SECRET=your_shopify_webhook_secret
REACT_APP_SHOPIFY_ACCESS_TOKEN=your_shopify_access_token
REACT_APP_SHOPIFY_SHOP_DOMAIN=your_shopify_domain

# Stripe Keys
REACT_APP_STRIPE_SECRET_KEY=your_stripe_secret_key
REACT_APP_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key

# Supabase Keys
REACT_APP_SUPABASE_URL=your_supabase_url
REACT_APP_SUPABASE_ANON_KEY=your_supabase_anon_key
REACT_APP_SUPABASE_SERVICE_KEY=your_supabase_service_key

# Shopify OAuth
REACT_APP_SHOPIFY_API_KEY=your_shopify_api_key
REACT_APP_SHOPIFY_API_SECRET=your_shopify_api_secret
REACT_APP_APP_URL=https://your-app-url.com

# API Version
REACT_APP_SHOPIFY_API_VERSION=2025-01

# Environment
REACT_APP_NODE_ENV=development
